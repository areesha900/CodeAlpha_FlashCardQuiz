<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EMOTILOG - 27100361"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="20dp" />

        <!-- emotion btns grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="4"
            android:useDefaultMargins="true">

            <Button
                android:id="@+id/btnHappy"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:text="😀 Happy"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnSad"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:text="😢 Sad"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnAngry"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:text="😡 Angry"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnExcited"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:text="🤩 Excited"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnShy"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:text="🫣 Shy"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnMotivated"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:text="💪 Motivated"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnSick"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:text="🤒 Sick"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnScared"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:text="😱 Scared"
                android:textSize="18sp" />

        </GridLayout>

        <!-- navigation btns -->

        <Button
            android:id="@+id/btnViewLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Logs"
            android:layout_marginTop="10dp"
            android:textSize="18sp" />


        <Button
            android:id="@+id/btnSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Summary"
            android:layout_marginTop="10dp"
            android:textSize="18sp" />


    </LinearLayout>

</ScrollView>
